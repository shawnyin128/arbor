{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'ROOT=\"${ARBOR_PLUGIN_ROOT:-${PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}}}\"; test -n \"$ROOT\" || exit 0; exec \"$ROOT/hooks/session-start\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'ROOT=\"${ARBOR_PLUGIN_ROOT:-${PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-}}}}\"; test -n \"$ROOT\" || exit 0; exec \"$ROOT/hooks/stop-memory-hygiene\"'"
          }
        ]
      }
    ]
  }
}

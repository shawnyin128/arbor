#!/usr/bin/env python3
"""Claude Code SessionStart hook adapter for Arbor.

Reads Claude Code hook event JSON from stdin, invokes the shared Arbor
startup-context script with the project root, applies a truncation policy
sized for Claude Code's ``additionalContext`` injection cap (10K chars),
and emits the trimmed packet to stdout. Plain stdout from a SessionStart
hook is automatically treated as ``additionalContext`` by Claude Code, so
no JSON envelope is needed for the success path.

Soft-fails on stderr with a non-zero exit code rather than blocking the
session: a missing ``cwd``, an unreadable shared script, or a downstream
error all degrade to "no Arbor context this session" instead of failing
session start.
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path


# Claude Code caps additionalContext at 10K chars; overflow routes the
# excess to a file with a preview note. We aim under that with headroom
# so the truncation notice plus any wrapper-added text stays in budget.
INJECTION_BUDGET = 9500

# Sources we refresh context on. clear/compact mean the user just reset
# context deliberately; do not re-inject Arbor context in those cases.
RELEVANT_SOURCES = {"startup", "resume"}

TRUNCATION_NOTICE = (
    "[truncated - Arbor SessionStart context exceeded the runtime "
    "injection budget; the agent can run deeper reads on demand]"
)


def _emit_error(message: str) -> None:
    print(f"arbor session-start: {message}", file=sys.stderr)


def resolve_plugin_root() -> Path:
    env = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if env:
        return Path(env).resolve()
    return Path(__file__).resolve().parent.parent


def parse_hook_payload(raw: str) -> dict:
    if not raw.strip():
        return {}
    return json.loads(raw)


def split_sections(packet: str) -> tuple[str, list[tuple[str, str]]]:
    """Split rendered startup context into preamble plus markdown sections."""
    lines = packet.splitlines(keepends=True)
    sections: list[tuple[str, str]] = []
    preamble: list[str] = []
    current_header: str | None = None
    current_body: list[str] = []

    for line in lines:
        if line.startswith("## "):
            if current_header is None:
                preamble = current_body
            else:
                sections.append((current_header, "".join(current_body)))
            current_header = line.rstrip("\n")
            current_body = []
            continue
        current_body.append(line)

    if current_header is None:
        return "".join(current_body), []
    sections.append((current_header, "".join(current_body)))
    return "".join(preamble), sections


def render_sections(preamble: str, sections: list[tuple[str, str]]) -> str:
    rendered = preamble
    for header, body in sections:
        rendered += f"{header}\n{body}"
    return rendered


def truncate_named_section(packet: str, section_prefix: str) -> str:
    preamble, sections = split_sections(packet)
    if not sections:
        return packet
    replaced: list[tuple[str, str]] = []
    for header, body in sections:
        if header.startswith(section_prefix):
            replaced.append((header, f"\n{TRUNCATION_NOTICE}\n\n"))
        else:
            replaced.append((header, body))
    return render_sections(preamble, replaced)


def apply_budget(packet: str, budget: int) -> str:
    if len(packet) <= budget:
        return packet

    # Claude Code has a transport cap for injected context. Trim optional
    # startup sections first while preserving section headers so the agent
    # still knows what to read on demand.
    trimmed = truncate_named_section(packet, "## 2. formatted git log")
    if len(trimmed) <= budget:
        return trimmed

    trimmed = truncate_named_section(trimmed, "## 1. AGENTS.md")
    if len(trimmed) <= budget:
        return trimmed

    trimmed = truncate_named_section(trimmed, "## 3. .arbor/memory.md")
    if len(trimmed) <= budget:
        return trimmed

    trimmed = truncate_named_section(trimmed, "## 4. git status")
    if len(trimmed) <= budget:
        return trimmed

    # Extremely small budgets should still return a useful diagnostic rather
    # than an arbitrary prefix of a large packet.
    return (trimmed[: max(0, budget - len(TRUNCATION_NOTICE) - 2)].rstrip() + "\n" + TRUNCATION_NOTICE + "\n")[:budget]


def main() -> int:
    try:
        payload = parse_hook_payload(sys.stdin.read())
    except json.JSONDecodeError as exc:
        _emit_error(f"could not parse hook event JSON: {exc}")
        return 1

    source = payload.get("source")
    if source is not None and source not in RELEVANT_SOURCES:
        return 0

    cwd = payload.get("cwd")
    if not cwd:
        _emit_error("hook event payload missing 'cwd'; skipping startup context")
        return 1

    plugin_root = resolve_plugin_root()
    script = plugin_root / "skills" / "arbor" / "scripts" / "run_session_startup_hook.py"
    if not script.is_file():
        _emit_error(f"shared startup script not found at {script}")
        return 1

    proc = subprocess.run(
        [sys.executable, str(script), "--root", cwd],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
    )
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or "no output"
        _emit_error(f"shared startup script exited {proc.returncode}: {detail}")
        return 1

    sys.stdout.write(apply_budget(proc.stdout, INJECTION_BUDGET))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

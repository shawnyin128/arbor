#!/usr/bin/env python3
"""Stop hook adapter for Arbor context maintenance.

Reads Codex or Claude Code ``Stop`` hook event JSON from stdin and quietly
keeps project-local Arbor context recoverable before the session stops.

This adapter is the Stop-time maintenance path for both:

* ``.arbor/memory.md`` recovery notes, when current Arbor context would be hard
  for the next agent to recover from committed history, durable docs, startup
  guidance, and git status alone.
* conservative ``AGENTS.md`` Project Map drift updates, when durable top-level
  entrypoints are missing from the map, stale entries remain, or generated
  nested primary map entries should be folded into top-level entries.

``Stop`` output can re-enter the agent loop as a visible continuation. That can
hide the assistant's real final response in runtimes that display the last
assistant message as the turn result, so the default path is silent and
non-blocking. Set ``ARBOR_STOP_MEMORY_HYGIENE_MODE=block`` to opt into the old
memory-hygiene packet continuation for debugging.

The adapter still self-gates:

* ``stop_hook_active`` is honored first -- once the runtime is already continuing
  because of this hook, the adapter allows the stop so it can never loop.
* Projects without an ``.arbor`` directory are not Arbor-managed; the
  adapter stays silent rather than blocking unrelated repositories.
* Explicit no-write payloads or ``ARBOR_STOP_NO_WRITE=1`` suppress mutation.
* Clean direct turns do not mutate memory unless bounded transcript context
  proves Arbor recovery context is present.
* Dirty Arbor worktrees stay silent by default, preventing hook prompts from
  replacing the user-facing final answer.

Empty probe payloads, missing ``cwd``, git launch failures, helper timeouts, and
helper launch failures soft-exit with code 0 so hook UIs can validate the
command without showing a failure or blocking the stop. Shared script nonzero
exits still report stderr and exit non-zero.
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
import re
from pathlib import Path


# The block reason is fed back to the model. Keep it bounded so a very large
# dirty diff stat cannot blow up the continuation prompt; the agent can
# always run deeper git reads on demand.
REASON_BUDGET = 12000
MODE_ENV = "ARBOR_STOP_MEMORY_HYGIENE_MODE"
MEMORY_TEMPLATE_RELATIVE = Path("skills") / "arbor" / "references" / "memory-template.md"
MEMORY_PATH_RELATIVE = Path(".arbor") / "memory.md"
PROJECT_GUIDE_PATH = Path("AGENTS.md")
NO_OBSERVATIONS_MARKERS = {
    "- No undecided short-term observations recorded yet.",
    "- No active Arbor resume context recorded yet.",
}
PLACEHOLDER_LINES = {
    "none",
    "none.",
    "n/a",
    "not applicable",
    "no unresolved state",
    "no active arbor resume context recorded yet.",
    "no undecided short-term observations recorded yet.",
}
OLD_FALLBACK_PREFIX = "stop hook fallback: dirty Arbor worktree detected before stop"
HOOK_FALLBACK_MARKER = "[hook:fallback]"
HOOK_RESUME_MARKER = "[hook:resume]"
HOOK_MANAGED_MARKERS = (HOOK_FALLBACK_MARKER, HOOK_RESUME_MARKER)
FALLBACK_TEMPLATE = """# Session Memory

<!--
Use this file to help the next agent resume current Arbor work that is not
committed or durable elsewhere.
-->

## Observations

<!-- Confirmed and already documented findings do not need to live here. -->

## In-flight

- No active Arbor resume context recorded yet.
"""
PROJECT_MAP_HEADING = "Project Map"
MAP_TOKEN_RE = re.compile(r"`([^`\n]+)`")
LIST_ITEM_RE = re.compile(r"^\s*[-*]\s+")
MAP_LIST_PATH_RE = re.compile(r"^\s*[-*]\s+([A-Za-z0-9._/-]+/?)(?=\s*(?::|-|--|$))")
SKIP_PROJECT_MAP_NAMES = {
    ".DS_Store",
    ".arbor",
    ".claude",
    ".codex",
    ".git",
    ".gitignore",
    ".meridian",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    ".venv",
    "__pycache__",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "artifacts",
    "build",
    "dist",
    "fixture",
    "fixtures",
    "logs",
    "node_modules",
    "output",
    "outputs",
    "scratch",
    "temp",
    "tmp",
    "venv",
}
INCLUDE_PROJECT_MAP_FILES = {"Makefile", "README.md", "package.json", "pyproject.toml"}
TRANSCRIPT_BUDGET = 64000
DEFAULT_INTERNAL_SUBPROCESS_TIMEOUT_SECONDS = 10.0

TRUNCATION_NOTICE = (
    "[truncated - Arbor memory hygiene packet exceeded the adapter budget; "
    "the agent can run deeper git reads on demand]"
)
PROBE_PAYLOAD_MARKER = "__arbor_probe_payload__"


def _emit_error(message: str) -> None:
    print(f"arbor stop-memory-hygiene: {message}", file=sys.stderr)


def looks_like_arbor_plugin_root(root: Path) -> bool:
    return (
        (root / ".codex-plugin" / "plugin.json").is_file()
        and (root / ".claude-plugin" / "plugin.json").is_file()
        and (root / "skills" / "arbor" / "SKILL.md").is_file()
    )


def allow_stop() -> int:
    print(json.dumps({"continue": True, "suppressOutput": True}))
    return 0


def block_stop(reason: str, system_message: str) -> int:
    output = {
        "decision": "block",
        "reason": apply_budget(reason, REASON_BUDGET),
        "systemMessage": system_message,
    }
    print(json.dumps(output))
    return 0


def resolve_plugin_root() -> Path:
    for env_name in ("ARBOR_PLUGIN_ROOT", "PLUGIN_ROOT", "CODEX_PLUGIN_ROOT", "CLAUDE_PLUGIN_ROOT"):
        env = os.environ.get(env_name)
        if env:
            try:
                root = Path(env).expanduser().resolve()
                if looks_like_arbor_plugin_root(root):
                    return root
            except (OSError, RuntimeError):
                continue
    return Path(__file__).resolve().parent.parent


def parse_hook_payload(raw: str) -> dict:
    normalized = raw.lstrip("\ufeff")
    if not normalized.strip():
        return {}
    data = json.loads(normalized)
    if not isinstance(data, dict):
        return {PROBE_PAYLOAD_MARKER: True}
    return data


def git_status_lines(root: Path) -> list[str]:
    try:
        proc = subprocess.run(
            ["git", "-C", str(root), "status", "--porcelain=v1", "-z", "--untracked-files=all"],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=internal_subprocess_timeout_seconds(),
        )
    except subprocess.TimeoutExpired:
        return []
    except OSError:
        return []
    if proc.returncode != 0:
        return []
    return parse_porcelain_z_status(proc.stdout)


def parse_porcelain_z_status(output: str) -> list[str]:
    records = output.split("\0")
    lines: list[str] = []
    index = 0
    while index < len(records):
        record = records[index]
        if not record:
            index += 1
            continue
        status = record[:2]
        path = record[3:] if len(record) > 3 else ""
        if any(flag in status for flag in ("R", "C")) and index + 1 < len(records):
            old_path = records[index + 1]
            if old_path:
                lines.append(f"{status} {old_path} -> {path}")
            else:
                lines.append(record)
            index += 2
            continue
        lines.append(record)
        index += 1
    return lines


def project_has_arbor_plugin_source(root: Path) -> bool:
    plugin_root = root / "plugins" / "arbor"
    return (
        (plugin_root / ".codex-plugin" / "plugin.json").is_file()
        and (plugin_root / ".claude-plugin" / "plugin.json").is_file()
        and (plugin_root / "skills" / "arbor" / "SKILL.md").is_file()
    )


def arbor_managed_status_lines(root: Path, status_lines: list[str]) -> list[str]:
    managed_prefixes = (
        ".arbor/",
        ".codex/hooks",
        ".codex/hooks.json",
        ".claude/hooks",
        ".claude/settings.json",
    )
    if project_has_arbor_plugin_source(root):
        managed_prefixes = (*managed_prefixes, "plugins/arbor/")
    managed_exact = {"AGENTS.md", "CLAUDE.md"}
    selected: list[str] = []
    for line in status_lines:
        paths = [path.replace("\\", "/") for path in parse_status_paths(line)]
        if any(path in managed_exact or any(path.startswith(prefix) for prefix in managed_prefixes) for path in paths):
            selected.append(line)
    return selected


def project_is_arbor_managed(root: Path, status_lines: list[str]) -> bool:
    if (root / ".arbor").is_dir():
        return True
    for line in status_lines:
        paths = [path.replace("\\", "/") for path in parse_status_paths(line)]
        if any(path.startswith(".arbor/") for path in paths):
            return True
    return False


def blocking_mode_enabled() -> bool:
    return os.environ.get(MODE_ENV, "silent").strip().lower() == "block"


def internal_subprocess_timeout_seconds() -> float:
    raw = os.environ.get("ARBOR_STOP_INTERNAL_TIMEOUT_SECONDS")
    if not raw:
        return DEFAULT_INTERNAL_SUBPROCESS_TIMEOUT_SECONDS
    try:
        value = float(raw)
    except ValueError:
        return DEFAULT_INTERNAL_SUBPROCESS_TIMEOUT_SECONDS
    if value <= 0:
        return DEFAULT_INTERNAL_SUBPROCESS_TIMEOUT_SECONDS
    return value


def apply_budget(packet: str, budget: int) -> str:
    if len(packet) <= budget:
        return packet
    head = packet[: max(0, budget - len(TRUNCATION_NOTICE) - 2)].rstrip()
    return f"{head}\n\n{TRUNCATION_NOTICE}\n"


def extract_in_flight_section(text: str) -> str:
    match = re.search(r"(?ms)^## In-flight\s*\n(?P<body>.*?)(?=^## |\Z)", text)
    if not match:
        return ""
    return match.group("body")


def memory_entry_state(text: str) -> str:
    if not text.strip():
        return "empty"
    body = extract_in_flight_section(text)
    if not body.strip():
        return "missing_section"

    bullets: list[str] = []
    for raw_line in body.splitlines():
        line = raw_line.strip()
        if not line.startswith("-"):
            continue
        bullets.append(line)

    if not bullets:
        return "placeholder"

    non_placeholder: list[str] = []
    for line in bullets:
        normalized = line.strip("-* ").strip().lower()
        if line in NO_OBSERVATIONS_MARKERS or normalized in PLACEHOLDER_LINES:
            continue
        if normalized.startswith(OLD_FALLBACK_PREFIX):
            continue
        non_placeholder.append(line)

    if not non_placeholder:
        return "placeholder"
    if all(any(marker in line for marker in HOOK_MANAGED_MARKERS) for line in non_placeholder):
        return "hook_fallback"
    return "explicit"


def has_current_resume_memory(text: str) -> bool:
    return memory_entry_state(text) == "explicit"


def parse_status_path(line: str) -> str:
    path = line[3:] if len(line) > 3 else line
    if " -> " in path:
        path = path.split(" -> ", 1)[1]
    return path.strip()


def parse_status_paths(line: str) -> list[str]:
    path = line[3:] if len(line) > 3 else line
    if " -> " not in path:
        stripped = path.strip()
        return [stripped] if stripped else []
    return [part.strip() for part in path.split(" -> ", 1) if part.strip()]


def compact_paths(status_lines: list[str], limit: int = 5) -> list[str]:
    paths = [parse_status_path(line) for line in status_lines if parse_status_path(line)]
    return paths[:limit]


def likely_area(paths: list[str], transcript_context: bool) -> str:
    joined = "\n".join(paths)
    if "AGENTS.md" in paths or "AGENTS.md" in joined:
        return "AGENTS.md guide drift"
    if ".arbor/memory.md" in paths or ".arbor/" in joined:
        return "Arbor memory state"
    if "plugins/arbor/hooks" in joined or ".codex/hooks" in joined or ".claude/hooks" in joined:
        return "Arbor Stop hook behavior"
    if "plugins/arbor/skills" in joined:
        return "Arbor skill contract"
    if transcript_context:
        return "recent Arbor conversation"
    return "dirty Arbor worktree"


def infer_checkpoint(paths: list[str], transcript_context: bool) -> str:
    joined = "\n".join(paths)
    if "plugins/arbor/hooks/" in joined or ".codex/hooks" in joined or ".claude/hooks" in joined:
        return "hook implementation or registration repair"
    if "AGENTS.md" in paths or "AGENTS.md" in joined:
        return "project guide drift update"
    if transcript_context:
        return "conversation-only Arbor continuation"
    return "dirty Arbor worktree"


def build_resume_entry(
    project_root: Path,
    status_lines: list[str],
    transcript_context: bool,
    transcript_path: Path | None,
) -> str:
    paths = compact_paths(status_lines)
    area = likely_area(paths, transcript_context)
    checkpoint = infer_checkpoint(paths, transcript_context)
    if paths:
        files = ", ".join(f"`{path}`" for path in paths)
        if len(status_lines) > len(paths):
            files = f"{files}, and {len(status_lines) - len(paths)} more path(s)"
    elif transcript_context and transcript_path is not None:
        files = f"recent Stop transcript `{transcript_path}`"
    else:
        files = "no specific dirty path was available"
    return (
        f"- {HOOK_RESUME_MARKER} Discussion: {area}. Files: {files}. "
        f"Checkpoint: {checkpoint}. Unresolved: Stop detected Arbor work that is "
        "not yet recoverable from committed history alone. Next: resume from the "
        "listed paths, inspect memory and git status, and decide whether "
        "`.arbor/memory.md`, `AGENTS.md`, or a commit should become the durable "
        "recovery boundary."
    )


def upsert_in_flight_fallback(text: str, entry: str) -> str:
    normalized = text.rstrip()
    replacement = f"## In-flight\n\n{entry}\n"
    if not normalized:
        return FALLBACK_TEMPLATE

    headings = list(re.finditer(r"(?m)^## [^\n]*\n?", normalized))
    if not headings:
        return f"{normalized}\n\n{replacement}"

    output = [normalized[: headings[0].start()].rstrip()]
    inserted = False
    for index, heading in enumerate(headings):
        end = headings[index + 1].start() if index + 1 < len(headings) else len(normalized)
        section = normalized[heading.start():end].strip()
        heading_text = heading.group(0).strip()
        if heading_text == "## In-flight":
            if not inserted:
                output.append(replacement.rstrip())
                inserted = True
            continue
        output.append(section)
    if not inserted:
        output.append(replacement.rstrip())
    return "\n\n".join(part for part in output if part).rstrip() + "\n"


def read_memory_template(plugin_root: Path) -> str:
    template = plugin_root / MEMORY_TEMPLATE_RELATIVE
    if template.is_file():
        return template.read_text(encoding="utf-8")
    return FALLBACK_TEMPLATE


def prune_hook_fallback_memory(project_root: Path) -> bool:
    memory_path = project_root / MEMORY_PATH_RELATIVE
    if not memory_path.is_file():
        return False
    text = memory_path.read_text(encoding="utf-8")
    if memory_entry_state(text) != "hook_fallback":
        return False
    updated = upsert_in_flight_fallback(text, "- No active Arbor resume context recorded yet.")
    if updated != text:
        memory_path.write_text(updated, encoding="utf-8")
        return True
    return False


def refresh_quiet_memory_fallback(
    project_root: Path,
    plugin_root: Path,
    status_lines: list[str],
    transcript_context: bool,
    transcript_path: Path | None,
) -> bool:
    memory_path = project_root / MEMORY_PATH_RELATIVE
    if memory_path.exists() and not memory_path.is_file():
        raise OSError(f"{memory_path} exists but is not a file")

    if memory_path.exists():
        text = memory_path.read_text(encoding="utf-8")
    else:
        text = read_memory_template(plugin_root)

    if text.strip() and has_current_resume_memory(text):
        return False

    if not text.strip():
        text = read_memory_template(plugin_root)
    updated = upsert_in_flight_fallback(text, build_resume_entry(project_root, status_lines, transcript_context, transcript_path))
    memory_path.parent.mkdir(parents=True, exist_ok=True)
    if not memory_path.exists() or memory_path.read_text(encoding="utf-8") != updated:
        memory_path.write_text(updated, encoding="utf-8")
        return True
    return False


def read_tail(path: Path, budget: int) -> str:
    if not path.is_file():
        return ""
    try:
        size = path.stat().st_size
        with path.open("rb") as fh:
            if size > budget:
                fh.seek(max(0, size - budget))
            data = fh.read(budget)
        return data.decode("utf-8", errors="replace")
    except OSError:
        return ""


def transcript_suggests_arbor_resume_context(payload: dict) -> tuple[bool, Path | None]:
    raw_path = payload.get("transcript_path")
    if not isinstance(raw_path, str) or not raw_path:
        return False, None
    path = Path(raw_path)
    text = read_tail(path, TRANSCRIPT_BUDGET)
    if not text:
        return False, path
    lowered = text.lower()
    arbor_terms = (".arbor/memory.md", "agents.md", "arbor", "stop hook", "guide drift")
    continuation_terms = (
        "resume",
        "continue",
        "next step",
        "fix",
        "bug",
        "problem",
        "boundary",
        "update",
        "memory",
        "hook",
    )
    return any(term in lowered for term in arbor_terms) and any(term in lowered for term in continuation_terms), path


def no_write_requested(payload: dict) -> bool:
    if os.environ.get("ARBOR_STOP_NO_WRITE", "").strip().lower() in {"1", "true", "yes"}:
        return True
    if payload.get("no_write") is True or payload.get("read_only") is True:
        return True
    mode = str(payload.get("permissionMode", "") or payload.get("permission_mode", "")).strip().lower()
    return mode in {"read-only", "readonly", "plan", "no-write"}


def extract_agents_section_bounds(text: str, heading: str) -> tuple[int, int, int] | None:
    pattern = re.compile(rf"(?m)^##\s+{re.escape(heading)}\s*$")
    match = pattern.search(text)
    if not match:
        return None
    body_start = match.end()
    if body_start < len(text) and text[body_start] == "\n":
        body_start += 1
    next_heading = re.search(r"(?m)^##\s+", text[body_start:])
    body_end = body_start + next_heading.start() if next_heading else len(text)
    return match.start(), body_start, body_end


def normalize_map_token(raw: str) -> str:
    token = raw.strip().strip("'\"")
    while token.startswith("./"):
        token = token[2:]
    return token


def is_project_map_entry_token(token: str) -> bool:
    if not token or token.startswith("#"):
        return False
    if any(char.isspace() for char in token):
        return False
    if "://" in token:
        return False
    path = Path(token.rstrip("/"))
    if path.is_absolute():
        return False
    return bool(path.parts)


def map_line_token(line: str) -> str | None:
    if not LIST_ITEM_RE.match(line):
        return None
    backtick_match = MAP_TOKEN_RE.search(line)
    if backtick_match:
        token = normalize_map_token(backtick_match.group(1))
        return token if is_project_map_entry_token(token) else None
    match = MAP_LIST_PATH_RE.match(line)
    if match:
        token = normalize_map_token(match.group(1))
        return token if is_project_map_entry_token(token) else None
    return None


def project_map_tokens(project_map: str) -> set[str]:
    tokens: set[str] = set()
    for line in project_map.splitlines():
        token = map_line_token(line)
        if token:
            tokens.add(token)
    return tokens


def candidate_is_mapped(candidate: str, tokens: set[str]) -> bool:
    normalized = normalize_map_token(candidate)
    variants = {normalized}
    if normalized.endswith("/"):
        variants.add(normalized.rstrip("/"))
    else:
        variants.add(f"{normalized}/")
    return bool(variants & tokens)


def is_top_level_project_map_token(token: str) -> bool:
    normalized = normalize_map_token(token).rstrip("/")
    return bool(normalized) and "/" not in normalized


def project_map_token_exists(root: Path, token: str) -> bool:
    normalized = normalize_map_token(token)
    target = root / normalized.rstrip("/")
    if normalized.endswith("/"):
        return target.is_dir()
    return target.exists()


def project_map_candidates(root: Path) -> list[str]:
    candidates: list[str] = []
    try:
        children = sorted(root.iterdir(), key=lambda item: item.name.lower())
    except OSError:
        return []
    for child in children:
        if child.name in SKIP_PROJECT_MAP_NAMES or child.name.startswith("."):
            continue
        if child.is_dir():
            candidates.append(f"{child.name}/")
        elif child.is_file() and child.name in INCLUDE_PROJECT_MAP_FILES:
            candidates.append(child.name)
    return candidates


def durable_project_map_candidate_for_path(path: str) -> str | None:
    normalized = path.replace("\\", "/").strip()
    if not normalized:
        return None
    first = normalized.split("/", 1)[0]
    if not first or first in SKIP_PROJECT_MAP_NAMES or first.startswith("."):
        return None
    if "/" in normalized:
        return f"{first}/"
    if first in INCLUDE_PROJECT_MAP_FILES:
        return first
    return None


def status_project_map_drift_candidates(root: Path, status_lines: list[str]) -> list[str]:
    agents_path = root / PROJECT_GUIDE_PATH
    if not agents_path.is_file():
        return []
    try:
        text = agents_path.read_text(encoding="utf-8")
    except (OSError, UnicodeError):
        return []
    bounds = extract_agents_section_bounds(text, PROJECT_MAP_HEADING)
    if bounds is None:
        return []
    _heading_start, body_start, body_end = bounds
    tokens = project_map_tokens(text[body_start:body_end])
    candidates: list[str] = []
    for line in status_lines:
        for path in parse_status_paths(line):
            candidate = durable_project_map_candidate_for_path(path)
            if candidate and not candidate_is_mapped(candidate, tokens) and candidate not in candidates:
                candidates.append(candidate)
    return candidates


def describe_project_map_candidate(candidate: str) -> str:
    descriptions = {
        "README.md": "public project overview and usage notes",
        "Makefile": "repository command entrypoint",
        "package.json": "JavaScript package metadata and scripts",
        "pyproject.toml": "Python project metadata and tooling config",
        "docs/": "durable project documentation",
        "plugins/": "plugin packages and runtime integration code",
        "scripts/": "repository-level scripts and validation helpers",
        "src/": "source code",
        "tests/": "test suite",
        "tools/": "durable project tools",
    }
    return descriptions.get(candidate, "durable project entrypoint detected by Arbor Stop guide drift")


def refresh_agents_project_map(root: Path) -> bool:
    agents_path = root / PROJECT_GUIDE_PATH
    if not agents_path.is_file():
        return False
    text = agents_path.read_text(encoding="utf-8")
    bounds = extract_agents_section_bounds(text, PROJECT_MAP_HEADING)
    if bounds is None:
        return False
    _heading_start, body_start, body_end = bounds
    body = text[body_start:body_end]
    tokens = project_map_tokens(body)
    missing = [candidate for candidate in project_map_candidates(root) if not candidate_is_mapped(candidate, tokens)]
    stale = {token for token in tokens if not project_map_token_exists(root, token)}
    non_top_level = {token for token in tokens if not is_top_level_project_map_token(token)}
    if not missing and not stale and not non_top_level:
        return False

    kept_lines: list[str] = []
    for line in body.splitlines():
        token = map_line_token(line)
        if token and (token in stale or token in non_top_level):
            continue
        kept_lines.append(line.rstrip())

    while kept_lines and not kept_lines[-1].strip():
        kept_lines.pop()
    if missing and kept_lines:
        kept_lines.append("")
    for candidate in missing:
        kept_lines.append(f"- `{candidate}`: {describe_project_map_candidate(candidate)}.")

    new_body = "\n".join(kept_lines).rstrip() + "\n"
    updated = f"{text[:body_start]}{new_body}{text[body_end:].lstrip()}"
    if updated != text:
        agents_path.write_text(updated, encoding="utf-8")
        return True
    return False


def run_agents_guide_quality_check(project_root: Path, plugin_root: Path) -> tuple[bool, str]:
    script = plugin_root / "skills" / "arbor" / "scripts" / "check_agents_guide_quality.py"
    if not script.is_file():
        return True, ""
    try:
        proc = subprocess.run(
            [sys.executable, str(script), "--root", str(project_root)],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=internal_subprocess_timeout_seconds(),
        )
    except subprocess.TimeoutExpired:
        return True, ""
    except OSError:
        return True, ""
    output = proc.stdout.strip() or proc.stderr.strip()
    return proc.returncode == 0, output


def main() -> int:
    raw_payload = sys.stdin.read()
    if not raw_payload.strip():
        return 0
    try:
        payload = parse_hook_payload(raw_payload)
    except json.JSONDecodeError as exc:
        return allow_stop()
    if payload.get(PROBE_PAYLOAD_MARKER):
        return allow_stop()

    # Claude is already continuing because of this hook; allowing the stop
    # here is what guarantees the adapter can never loop.
    if payload.get("stop_hook_active"):
        return allow_stop()

    cwd = payload.get("cwd")
    if not isinstance(cwd, str) or not cwd.strip():
        _emit_error("hook event payload missing 'cwd'; not blocking stop")
        return allow_stop()

    project_root = Path(cwd)
    status_lines = git_status_lines(project_root)
    # Only Arbor-managed projects keep an `.arbor` directory; staying silent
    # everywhere else keeps unrelated repositories unblocked. A tracked
    # deletion under `.arbor/` still counts as Arbor-managed so Stop can
    # recreate the recovery file before the session ends.
    if not project_is_arbor_managed(project_root, status_lines):
        return allow_stop()

    if no_write_requested(payload):
        return allow_stop()

    plugin_root = resolve_plugin_root()
    arbor_status_lines = arbor_managed_status_lines(project_root, status_lines)
    dirty = bool(arbor_status_lines)
    transcript_context, transcript_path = transcript_suggests_arbor_resume_context(payload)
    project_map_drift = bool(status_project_map_drift_candidates(project_root, status_lines))
    try:
        if dirty or transcript_context:
            refresh_quiet_memory_fallback(project_root, plugin_root, arbor_status_lines, transcript_context, transcript_path)
        else:
            prune_hook_fallback_memory(project_root)
        if dirty or transcript_context or project_map_drift:
            refresh_agents_project_map(project_root)
            guide_ok, guide_output = run_agents_guide_quality_check(project_root, plugin_root)
            if not guide_ok:
                return block_stop(
                    guide_output,
                    "Arbor: AGENTS.md guide quality must be fixed before stop.",
                )
    except (OSError, UnicodeError) as exc:
        _emit_error(f"could not refresh quiet Stop context maintenance: {exc}")
        return allow_stop()

    # Default to silence: blocking Stop hooks create a visible continuation
    # that can hide the assistant's real final response in some runtimes.
    if not blocking_mode_enabled():
        return allow_stop()

    script = plugin_root / "skills" / "arbor" / "scripts" / "run_memory_hygiene_hook.py"
    if not script.is_file():
        _emit_error(f"shared memory hygiene script not found at {script}")
        return 1

    try:
        proc = subprocess.run(
            [sys.executable, str(script), "--root", cwd],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=internal_subprocess_timeout_seconds(),
        )
    except subprocess.TimeoutExpired as exc:
        _emit_error(f"shared memory hygiene script timed out after {exc.timeout:g}s")
        return allow_stop()
    except OSError as exc:
        _emit_error(f"shared memory hygiene script failed to start: {exc}")
        return allow_stop()
    if proc.returncode != 0:
        detail = proc.stderr.strip() or proc.stdout.strip() or "no output"
        _emit_error(f"shared memory hygiene script exited {proc.returncode}: {detail}")
        return 1

    return block_stop(proc.stdout, "Arbor: checking in-flight memory before stop.")


if __name__ == "__main__":
    raise SystemExit(main())
